<Page x:Class="Zarzadzanie_uczelnia.StudenciPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="StudenciPage">

    <Grid Background="#F5F7FA" Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Dodawanie studenta"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1" Padding="15" Background="White" CornerRadius="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                    <TextBlock Text="Imię" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Imie}" Height="30"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                    <TextBlock Text="Nazwisko" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Nazwisko}" Height="30"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="5">
                    <TextBlock Text="Telefon" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding NrTelefonu}" Height="30"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="3" Margin="5">
                    <TextBlock Text="Email" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Email}" Height="30"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                    <TextBlock Text="Kierunek" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Kierunki}"
                              SelectedItem="{Binding WybranyKierunek}"
                              Height="30"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                    <TextBlock Text="Rok Urodzenia" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Rok}" Height="30"/>
                </StackPanel>

                <TextBlock  Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" 
                       VerticalAlignment="Center"
                       Text="Grupa jest przydzielana automatycznie"/>


                <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                        Content="Dodaj studenta"
                        Height="40"
                        Margin="5,15,5,0"
                        Background="#4CAF50"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="AddStudent_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="10" Margin="0">
            <DataGrid ItemsSource="{Binding Studenci}"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch"/>
        </Border>

    </Grid>
</Page>