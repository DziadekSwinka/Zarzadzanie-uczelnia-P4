<Page x:Class="Zarzadzanie_uczelnia.Views.OcenyAddPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="OcenyAddPage">

    <Grid Background="#F5F7FA" Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Dodawanie oceny"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1" Padding="15" Background="White" CornerRadius="10">
            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                    <TextBlock Text="Wartość oceny" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding WartoscOceny}" Height="30"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                    <TextBlock Text="Kierunek" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Kierunki}"
                              SelectedItem="{Binding WybranyKierunek}"
                              Height="30"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                    <TextBlock Text="Grupa" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Grupy}"
                              SelectedItem="{Binding WybranaGrupa}"
                              Height="30"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                    <TextBlock Text="Przedmiot" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Przedmioty}"
                              SelectedItem="{Binding WybranyPrzedmiot}"
                              Height="30"/>
                </StackPanel>
                
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="5">
                    <TextBlock Text="Student" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Studenci}"
                            SelectedItem="{Binding WybranyStudent}"
                            DisplayMemberPath="Display"
                            Height="30"/>
                </StackPanel>

                <Button Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="1"
                        Content="Dodaj ocenę"
                        Height="40"
                        Margin="5,15,5,0"
                        Background="#4CAF50"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="DodajOcene_Click"/>

            </Grid>
        </Border>

    </Grid>
</Page>