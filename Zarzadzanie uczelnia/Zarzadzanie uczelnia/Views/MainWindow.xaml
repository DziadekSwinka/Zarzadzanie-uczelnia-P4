<Window x:Class="Zarzadzanie_uczelnia.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zarządzanie uczelnią"
        Height="550" Width="950"
        Background="#F5F7FA">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#4A90E2">
            <Grid Margin="20,0">
                <TextBlock Text="Zarządzanie uczelnią"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
              HorizontalScrollBarVisibility="Auto"
              VerticalScrollBarVisibility="Disabled"
              Margin="20,15,20,10">

            <StackPanel Orientation="Horizontal">

                <Button Click="Studenci_Click" Margin="5" Background="White" BorderThickness="0" Width="140">
                    <Border CornerRadius="10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="👨‍🎓" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Studenci" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>

                <Button Click="Grupy_Click" Margin="5" Background="White" BorderThickness="0" Width="140">
                    <Border CornerRadius="10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="📚" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Grupy" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>

                <Button Click="Oceny_click" Margin="5" Background="White" BorderThickness="0" Width="140">
                    <Border CornerRadius="10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="📊" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Oceny" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>

                <Button Click="DodajOcene_click" Margin="5" Background="White" BorderThickness="0" Width="140">
                    <Border CornerRadius="10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="➕" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Dodaj ocenę" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>

                <Button Click="Przedmioty_Click" Margin="5" Background="White" BorderThickness="0" Width="140">
                    <Border CornerRadius="10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="📖" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Przedmioty" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>

                <Button Click="Kierunek_Click" Margin="5" Background="White" BorderThickness="0" Width="140">
                    <Border CornerRadius="10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="🎓" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Kierunki" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="10"
                Margin="20,0,20,20"
                Padding="10">

            <Frame x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   Navigated="MainFrame_Navigated"/>

        </Border>

    </Grid>
</Window>